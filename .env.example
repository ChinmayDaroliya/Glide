# Glide - Instagram Automation Platform Environment Variables

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL="postgresql://username:password@localhost:5432/glide"

# ==========================================
# AUTHENTICATION (Clerk)
# ==========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"
CLERK_SECRET_KEY="your_clerk_secret_key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/dashboard"

# ==========================================
# HOST CONFIGURATION
# ==========================================
NEXT_PUBLIC_HOST_URL="http://localhost:3000"
# For production: NEXT_PUBLIC_HOST_URL="https://your-domain.com"

# ==========================================
# INSTAGRAM INTEGRATION
# ==========================================
INSTAGRAM_CLIENT_ID="your_instagram_client_id"
INSTAGRAM_CLIENT_SECRET="your_instagram_client_secret"
INSTAGRAM_TOKEN_URL="https://api.instagram.com/oauth/access_token"
INSTAGRAM_BASE_URL="https://graph.instagram.com"
INSTAGRAM_REDIRECT_URI="http://localhost:3000/callback/instagram"
# For production: INSTAGRAM_REDIRECT_URI="https://your-domain.com/callback/instagram"

# Instagram OAuth Scopes - Required permissions
INSTAGRAM_OAUTH_SCOPE="instagram_basic,instagram_manage_messages,instagram_manage_comments,pages_show_list,pages_read_engagement"

# Instagram OAuth State Secret - Must match across all environments
INSTAGRAM_OAUTH_STATE_SECRET="your_secure_oauth_state_secret"

# ==========================================
# OPENAI INTEGRATION (Optional)
# ==========================================
OPEN_AI_KEY="your_openai_api_key"

# ==========================================
# STRIPE PAYMENT INTEGRATION
# ==========================================
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_CLIENT_SECRET="your_stripe_client_secret"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"
STRIPE_SUBSCRIPTION_PRICE_ID="price_your_subscription_price_id"